ey you, you have no right to act against them: God is most high and great."}]},{"id":528,"verse_number":35,"verse_key":"4:35","hizb_number":9,"rub_el_hizb_number":33,"ruku_number":67,"manzil_number":1,"sajdah_number":null,"text_qpc_hafs":"وَإِنۡ خِفۡتُمۡ شِقَاقَ بَيۡنِهِمَا فَٱبۡعَثُواْ حَكَمٗا مِّنۡ أَهۡلِهِۦ وَحَكَمٗا مِّنۡ أَهۡلِهَآ إِن يُرِيدَآ إِصۡلَٰحٗا يُوَفِّقِ ٱللَّهُ بَيۡنَهُمَآۗ إِنَّ ٱللَّهَ كَانَ عَلِيمًا خَبِيرٗا ٣٥","text_uthmani":"وَإِنْ خِفْتُمْ شِقَاقَ بَيْنِهِمَا فَٱبْعَثُوا۟ حَكَمًا مِّنْ أَهْلِهِۦ وَحَكَمًا مِّنْ أَهْلِهَآ إِن يُرِيدَآ إِصْلَـٰحًا يُوَفِّقِ ٱللَّهُ بَيْنَهُمَآ ۗ إِنَّ ٱللَّهَ كَانَ عَلِيمًا خَبِيرًا","page_number":84,"juz_number":5,"words":[{"id":36976,"position":1,"audio_url":"wbw/004_035_001.mp3","char_type_name":"word","text_qpc_hafs":"وَإِنۡ","text_uthmani":"وَإِنْ","line_number":6,"text_uthmani_tajweed":"وَإِنۡ","page_number":84,"text":"وَإِنْ","translation":{"text":"And if","language_name":"english"},"transliteration":{"text":"wa-in","language_name":"english"}},{"id":36977,"position":2,"audio_url":"wbw/004_035_002.mp3","char_type_name":"word","text_qpc_hafs":"خِفۡتُمۡ","text_uthmani":"خِفْتُمْ","line_number":6,"text_uthmani_tajweed":"خِفۡتُمۡ","page_number":84,"text":"خِفْتُمْ","translation":{"text":"you fear","language_name":"english"},"transliteration":{"text":"khif'tum","language_name":"english"}},{"id":36978,"position":3,"audio_url":"wbw/004_035_003.mp3","char_type_name":"word","text_qpc_hafs":"شِقَاقَ","text_uthmani":"شِقَاقَ","line_number":6,"text_uthmani_tajweed":"شِقَاقَ","page_number":84,"text":"شِقَاقَ","translation":{"text":"a dissension","language_name":"english"},"transliteration":{"text":"shiqāqa","language_name":"english"}},{"id":36979,"position":4,"audio_url":"wbw/004_035_004.mp3","char_type_name":"word","text_qpc_hafs":"بَيۡنِهِمَا","text_uthmani":"بَيْنِهِمَا","line_number":7,"text_uthmani_tajweed":"بَيۡنِهِمَا","page_number":84,"text":"بَيْنِهِمَا","translation":{"text":"between (the) two of them",